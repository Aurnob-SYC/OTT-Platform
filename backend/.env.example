NODE_ENV=development

# Hostname or LAN IP other devices use to reach this machine.
LAN_HOST=127.0.0.1

# Local component ports.
FRONTEND_PORT=5173
BACKEND_PORT=4000
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997
MEDIAMTX_RTSP_PORT=8554
NGINX_PORT=80

# Override these when a component is bound to a different host, scheme, or path.
FRONTEND_BASE_URL=https://127.0.0.1:5173
BACKEND_BASE_URL=http://127.0.0.1:4000
MEDIAMTX_WEBRTC_BASE_URL=https://192.168.0.102:8889
MEDIAMTX_API_BASE_URL=http://127.0.0.1:9997
MEDIAMTX_RTSP_BASE_URL=rtsp://127.0.0.1:8554
NGINX_HLS_BASE_URL=http://127.0.0.1/hls
NGINX_VOD_BASE_URL=http://127.0.0.1/vod

# FFmpeg writes HLS output here. nginx should alias /hls/ to this directory.
HLS_MEDIA_ROOT=media/live

# Recording archives and generated VOD HLS live outside the live HLS root.
RECORDING_ARCHIVE_ROOT=media/archive
VOD_MEDIA_ROOT=media/vod
RECORDING_METADATA_FILE=recordings.json

# Shared pre-roll clip used when packaging recordings into VOD HLS.
PREROLL_SOURCE_PATH=media/ads/preroll/source.mp4

# Default is false to avoid deleting local output unexpectedly.
HLS_CLEAN_STALE_OUTPUT_ON_START=false

# External binaries are expected on PATH unless overridden.
# Point FFMPEG_BINARY at the actual ffmpeg.exe path. Do not use the FFmpeg source folder.
MEDIAMTX_BINARY=D:/tools/mediaMTX/mediamtx.exe
FFMPEG_BINARY=D:/path/to/ffmpeg/bin/ffmpeg.exe
NGINX_BINARY=D:/tools/nginx/nginx.exe

